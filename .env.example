# Google Cloud OAuth Credentials
# Create these at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Desktop application)
# 2. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: Use plaintext storage instead of OS keychain (for CI/Docker)
# GCP_PLAINTEXT_STORAGE=true

# Optional: Comma-separated list of enabled tools (default: read-only tools)
# ENABLED_TOOLS=list_events,get_event,find_free_time
